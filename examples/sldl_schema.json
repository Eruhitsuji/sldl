{
  "config_type": "sldl.schema",
  "description": "SLDL v1.0.3 bilingual official schema with template-schema bindings.",
  "schema_version": "1.0.3",
  "document_types": {
    "ResearchReport": {
      "required_blocks": [
        "meta"
      ],
      "allowed_top_level": [
        "meta",
        "section",
        "bibliography",
        "object"
      ],
      "allowed_node_kinds": [
        "Person",
        "Section",
        "Paragraph",
        "Claim",
        "Counterargument",
        "Reason",
        "Evidence",
        "Conclusion",
        "Reference",
        "Heading",
        "List",
        "Table",
        "Figure",
        "CodeBlock",
        "Reasoning",
        "Rebuttal",
        "Chart",
        "Flowchart"
      ],
      "required_meta": [
        "title",
        "author",
        "date"
      ],
      "required_nodes": [
        "Section"
      ],
      "template_name": "research_report_en",
      "template_dir": "../templates",
      "strict_schema": true
    },
    "ProjectOverview": {
      "required_blocks": [
        "meta"
      ],
